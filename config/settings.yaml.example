# Minimal Modular RAG Project - Example Settings

project:
  name: "minimal-modular-rag"
  environment: "local"

ingestion:
  default_collection: "default"
  chunk_size: 500
  chunk_overlap: 50
  supported_extensions:
    - ".txt"
    - ".md"

retrieval:
  dense_top_k: 5

adapters:
  loader:
    provider: "text"
  embedding:
    provider: "fake"
    dimensions: 16
  vector_store:
    provider: "memory"
    storage_path: "./data/db/vector_store.json"

observability:
  trace_enabled: true
  trace_file: "./data/traces/app.jsonl"
  log_level: "INFO"
