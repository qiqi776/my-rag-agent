# Minimal Modular RAG Project - Example Settings

project:
  name: "minimal-modular-rag"
  environment: "local"

ingestion:
  default_collection: "default"
  chunk_size: 500
  chunk_overlap: 50
  supported_extensions:
    - ".txt"
    - ".md"

retrieval:
  mode: "dense"
  dense_top_k: 5
  sparse_top_k: 5
  rrf_k: 60

generation:
  max_context_results: 3
  max_answer_chars: 400

adapters:
  loader:
    provider: "text"
  embedding:
    provider: "fake"
    dimensions: 16
  vector_store:
    provider: "local_json"
    storage_path: "./data/db/vector_store.json"
  llm:
    provider: "fake"
  reranker:
    provider: "fake"

observability:
  trace_enabled: true
  trace_file: "./data/traces/app.jsonl"
  log_level: "INFO"
